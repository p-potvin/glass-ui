{
  "name": "glass-ui",
  "version": "0.1.0",
  "description": "A Glass Rendering engine for all your Web Apps (React.js/Tailwind). Supports multiple glass styles and easily customizable!",
  "type": "module",
  "main": "dist/glass-ui.umd.cjs",
  "module": "dist/glass-ui.js",
  "types": "dist/glass-ui.d.ts",
  "exports": {
    ".": {
      "import": "./dist/glass-ui.js",
      "require": "./dist/glass-ui.umd.cjs",
      "types": "./dist/glass-ui.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.preview.config.ts",
    "build": "vite build",
    "build:preview": "vite build --config vite.preview.config.ts",
    "preview": "vite preview --config vite.preview.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "glass",
    "glassmorphism",
    "ui",
    "react",
    "tailwind",
    "components"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "three": "^0.184.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
