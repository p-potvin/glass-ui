<Window
    x:Class="GlassDemo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="glass-ui · WinUI 3 Glass Demo">

    <Grid x:Name="RootGrid" Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="glass-ui  ·  WinUI 3 Glass Demo"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#93a1a1" />
            <TextBlock Text="Native Mica, Acrylic and Blur materials via the Windows App SDK."
                       FontSize="14" Foreground="#839496" />
        </StackPanel>

        <!-- Backdrop selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
            <RadioButton x:Name="MicaRadio" Content="Mica" GroupName="Backdrop"
                         IsChecked="True" Click="OnBackdropChanged" />
            <RadioButton x:Name="MicaAltRadio" Content="Mica Alt" GroupName="Backdrop"
                         Click="OnBackdropChanged" />
            <RadioButton x:Name="AcrylicRadio" Content="Acrylic" GroupName="Backdrop"
                         Click="OnBackdropChanged" />
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="2" x:Name="StatusText"
                   FontSize="12" Foreground="#2aa198" />

        <!-- Info cards -->
        <Grid Grid.Row="3" ColumnSpacing="12" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Card: Mica -->
            <Border Grid.Column="0" CornerRadius="8" Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Mica" FontSize="16" FontWeight="SemiBold" Foreground="#268bd2" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#839496"
                               Text="System Mica material — samples the desktop wallpaper behind the window and applies a soft blur with colour tint." />
                </StackPanel>
            </Border>

            <!-- Card: Mica Alt -->
            <Border Grid.Column="1" CornerRadius="8" Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Mica Alt" FontSize="16" FontWeight="SemiBold" Foreground="#268bd2" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#839496"
                               Text="Stronger tinted variant of Mica used in tabbed windows. Appears slightly more opaque than standard Mica." />
                </StackPanel>
            </Border>

            <!-- Card: Acrylic -->
            <Border Grid.Column="2" CornerRadius="8" Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Acrylic" FontSize="16" FontWeight="SemiBold" Foreground="#268bd2" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#839496"
                               Text="In-app Acrylic — a semi-transparent, blurred material that shows content behind the surface within the window." />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="4" FontSize="11" Foreground="#586e75"
                   Text="Powered by Microsoft.UI.Composition SystemBackdropConfiguration"
                   Margin="0,8,0,0" />
    </Grid>
</Window>
